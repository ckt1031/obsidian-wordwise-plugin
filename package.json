{
	"name": "obsidian-wordwise-plugin",
	"version": "1.3.0",
	"private": true,
	"description": "Writing companion for AI content generation.",
	"license": "MIT",
	"author": "ckt1031",
	"main": "main.js",
	"scripts": {
		"build": "node esbuild.config.ts production",
		"dev": "node esbuild.config.ts",
		"format": "biome format . --write",
		"lint": "tsc --noEmit --skipLibCheck && biome check .",
		"lint:fix": "tsc --noEmit --skipLibCheck && biome check --write .",
		"test": "vitest run",
		"version": "node scripts/version-bump.ts && biome format manifest.json versions.json --write && git add manifest.json versions.json",
		"prepare": "husky || true",
		"lint-staged": "lint-staged"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^4.0.12",
		"@ai-sdk/google": "^4.0.12",
		"@ai-sdk/mistral": "^4.0.8",
		"@ai-sdk/openai": "^4.0.11",
		"@ai-sdk/provider": "^4.0.3",
		"@openrouter/ai-sdk-provider": "^3.0.0",
		"@types/mustache": "^4.2.6",
		"ai": "^7.0.22",
		"ai-sdk-ollama": "^4.0.0",
		"front-matter": "^4.0.2",
		"fuse.js": "7.1.0",
		"localforage": "1.10.0",
		"mustache": "^4.2.0",
		"nanoid": "5.1.6",
		"openai": "^6.46.0",
		"slugify": "1.6.6",
		"valibot": "1.2.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@types/node": "25.0.9",
		"builtin-modules": "5.0.0",
		"codemirror": "^6.0.2",
		"esbuild": "0.27.2",
		"husky": "9.1.7",
		"lint-staged": "16.2.7",
		"obsidian": "1.11.4",
		"tslib": "2.8.1",
		"typescript": "5.9.3",
		"vite": "^8.1.0",
		"vitest": "4.1.9"
	},
	"lint-staged": {
		"*.{js,ts,mjs,cjs}": [
			"biome check && tsc"
		]
	},
	"packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
